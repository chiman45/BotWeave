# Twilio API Credentials
# Get these from your Twilio Console: https://console.twilio.com/

# Your main Twilio Account SID (starts with 'AC')
TWILIO_ACCOUNT_SID=AC09fbbab319a74adf2d5c058fe4938b61

# Your main Twilio Auth Token
TWILIO_AUTH_TOKEN=60fea1c8b9cff3bd204c61275a14c7ec

# Your Twilio WhatsApp-enabled number (format: whatsapp:+<number>)
# Sandbox number: whatsapp:+14155238886
# For approved number: whatsapp:+<your_twilio_number>
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/

# Flask server port
PORT=5000

# Ngrok auth token — get from https://dashboard.ngrok.com/get-started/your-authtoken
# Set this for a stable subdomain and to avoid the 2-hour session limit
NGROK_AUTH_TOKEN=38UGUC4Y5LzClfCPHTk1naBGzdc_3paMsUtXW8tQMmWBzBgMo


# Ollama (local) — embeddings (RAG) + chat replies
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3

# Hybrid RAG — set to false to fall back to pure vector search
RAG_BM25_ENABLED=true

# Twilio WhatsApp sandbox join message (find it in Twilio Console → Messaging → Try it out → Send a WhatsApp message)
TWILIO_SANDBOX_KEYWORD=join twelve-claws

# Auto-set by setup_webhook.py
WEBHOOK_URL=https://spectrohelioscopic-shamika-perchloric.ngrok-free.dev/webhook/whatsapp
    
